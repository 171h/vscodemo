+function createConcurrencyLimiter(limit: number): <T>(task: () => Promise<T>) => Promise<T> {
+	let active = 0;
+	const pending: Array<() => void> = [];
+
+	const acquire = () => new Promise<void>(resolve => {
+		const start = () => {
+			active++;
+			resolve();
+		};
+
+		if (active < limit) {
+			start();
+		} else {
+			pending.push(start);
+		}
+	});
+
+	return async task => {
+		await acquire();
+		try {
+			return await task();
+		} finally {
+			active--;
+			pending.shift()?.();
+		}
+	};
+}
