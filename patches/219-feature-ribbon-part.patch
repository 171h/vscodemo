diff --git a/src/vs/workbench/browser/parts/ribbon/media/ribbonpart.css b/src/vs/workbench/browser/parts/ribbon/media/ribbonpart.css
new file mode 100644
index 0000000000000000000000000000000000000000..3d2484dc6bafd288de772bf2da12a5579107146f
--- /dev/null
+++ b/src/vs/workbench/browser/parts/ribbon/media/ribbonpart.css
@@ -0,0 +1,154 @@
+.monaco-workbench .part.ribbon {
+	background: var(--vscode-editor-background);
+	color: var(--vscode-foreground);
+	border-bottom: 1px solid var(--vscode-panel-border);
+}
+
+.ribbon-root {
+	display: flex;
+	flex-direction: column;
+	height: 100%;
+	min-width: 0;
+}
+
+.ribbon-tabs {
+	display: flex;
+	align-items: stretch;
+	height: 32px;
+	min-height: 32px;
+	padding-left: 6px;
+	border-bottom: 1px solid var(--vscode-panel-border);
+}
+
+.ribbon-tab,
+.ribbon-collapse,
+.ribbon-item {
+	border: 0;
+	color: inherit;
+	background: transparent;
+	font: inherit;
+}
+
+.ribbon-tab {
+	position: relative;
+	padding: 0 12px;
+	cursor: pointer;
+}
+
+.ribbon-tab:hover,
+.ribbon-item:hover:not(:disabled),
+.ribbon-collapse:hover {
+	background: var(--vscode-toolbar-hoverBackground);
+}
+
+.ribbon-tab[aria-selected="true"]::after {
+	position: absolute;
+	right: 8px;
+	bottom: 0;
+	left: 8px;
+	height: 2px;
+	content: '';
+	background: var(--vscode-focusBorder);
+}
+
+.ribbon-tab:focus-visible,
+.ribbon-item:focus-visible,
+.ribbon-collapse:focus-visible {
+	outline: 1px solid var(--vscode-focusBorder);
+	outline-offset: -1px;
+}
+
+.ribbon-collapse {
+	width: 32px;
+	margin-left: auto;
+	cursor: pointer;
+}
+
+.ribbon-content,
+.ribbon-overlay {
+	height: 98px;
+	box-sizing: border-box;
+	overflow-x: auto;
+	overflow-y: hidden;
+	background: var(--vscode-editor-background);
+	color: var(--vscode-foreground);
+	box-shadow: 0 4px 8px var(--vscode-widget-shadow);
+}
+
+.ribbon-groups {
+	display: flex;
+	align-items: stretch;
+	height: 100%;
+	width: max-content;
+	min-width: 100%;
+	padding: 3px 6px 2px;
+	box-sizing: border-box;
+}
+
+.ribbon-group {
+	display: flex;
+	flex-direction: column;
+	min-width: max-content;
+	padding: 0 6px;
+	border-right: 1px solid var(--vscode-panel-border);
+}
+
+.ribbon-items {
+	display: flex;
+	align-items: stretch;
+	gap: 2px;
+	height: 74px;
+}
+
+.ribbon-item {
+	display: flex;
+	align-items: center;
+	justify-content: center;
+	flex-direction: column;
+	min-width: 62px;
+	max-width: 118px;
+	padding: 2px 6px;
+	border-radius: 2px;
+	cursor: pointer;
+}
+
+.ribbon-items.compact .ribbon-item {
+	min-width: auto;
+	max-width: 150px;
+}
+
+.ribbon-item:disabled {
+	opacity: .45;
+	cursor: default;
+}
+
+.ribbon-item-icon {
+	width: 46px;
+	height: 46px;
+	font-size: 44px;
+	background-position: center;
+	background-repeat: no-repeat;
+	background-size: contain;
+}
+
+.ribbon-item-label {
+	max-width: 110px;
+	overflow: hidden;
+	font-size: 11px;
+	line-height: 15px;
+	text-align: center;
+	text-overflow: ellipsis;
+	white-space: nowrap;
+}
+
+.ribbon-group-title {
+	height: 14px;
+	font-size: 10px;
+	line-height: 14px;
+	text-align: center;
+	color: var(--vscode-descriptionForeground);
+}
+
+.ribbon-root.collapsed .ribbon-tabs {
+	border-bottom: 0;
+}
