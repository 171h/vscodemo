+function builtinActionFallbackIcon(tab: IBuiltinRibbonTab, action: IAction): ThemeIcon {
+	if (action instanceof SubmenuAction) {
+		return Codicon.listTree;
+	}
+
+	const id = action.id.toLowerCase();
+	if (id.includes('new') && id.includes('file')) {
+		return Codicon.newFile;
+	}
+	if (id.includes('new') && id.includes('window')) {
