+export class RibbonPart extends Part implements IRibbonService {
+	declare readonly _serviceBrand: undefined;
+
+	readonly minimumWidth = 0;
+	readonly maximumWidth = Number.POSITIVE_INFINITY;
+
+	get minimumHeight(): number { return this.collapsed ? COLLAPSED_HEIGHT : EXPANDED_HEIGHT; }
+	get maximumHeight(): number { return this.minimumHeight; }
+
+	private readonly tabDisposables = this._register(new DisposableStore());
+	private readonly contentDisposables = this._register(new DisposableStore());
+	private readonly contributionContextKeys = new Set<string>();
+	private root!: HTMLElement;
+	private tabList!: HTMLElement;
+	private tabButtons: HTMLButtonElement[] = [];
+	private content!: HTMLElement;
+	private collapseButton!: HTMLButtonElement;
+	private activeTabId: string;
+	private hasPersistedActiveTab: boolean;
+	private collapsed: boolean;
+	private overlay: IOpenContextView | undefined;
