+		this.render();
+		return this.root;
+	}
+
+	private visibleTabs(): RibbonTab[] {
+		const contributed = ribbonRegistry.tabs.filter(tab => this.matches(tab.when));
+		return [...BUILTIN_TABS, ...contributed].sort((a, b) => orderOf(a) - orderOf(b) || a.id.localeCompare(b.id));
+	}
+
+	private refreshContributionContextKeys(): void {
+		this.contributionContextKeys.clear();
+		for (const tab of ribbonRegistry.tabs) {
+			this.addContextKeys(ContextKeyExpr.deserialize(tab.when));
+			for (const group of tab.groups) {
+				this.addContextKeys(ContextKeyExpr.deserialize(group.when));
+				this.visitContributionItems(group.items, item => {
+					this.addContextKeys(ContextKeyExpr.deserialize(item.when));
+					this.addContextKeys(item.command ? MenuRegistry.getCommand(item.command)?.precondition : undefined);
+				});
+			}
+		}
+	}
+
+	private visitContributionItems(items: readonly IRibbonItemContribution[], visitor: (item: IRibbonItemContribution) => void): void {
+		for (const item of items) {
+			visitor(item);
+			if (item.menu?.items) {
+				this.visitContributionItems(item.menu.items, visitor);
+			}
+		}
+	}
+
+	private addContextKeys(expression: ContextKeyExpression | undefined): void {
+		for (const key of expression?.keys() ?? []) {
+			this.contributionContextKeys.add(key);
+		}
+	}
+
+	private matches(expression: string | undefined): boolean {
+		return !expression || this.contextKeyService.contextMatchesRules(ContextKeyExpr.deserialize(expression));
+	}
+
+	private ensureActiveTab(tabs: readonly RibbonTab[]): RibbonTab | undefined {
+		let active = tabs.find(tab => tab.id === this.activeTabId);
+		const defaultTab = tabs.find(tab => !isBuiltinTab(tab) && tab.default);
+		if (!active || (!this.hasPersistedActiveTab && defaultTab)) {
+			active = defaultTab ?? tabs[0];
+			this.activeTabId = active?.id ?? '';
+		}
+		return active;
+	}
+
+	private render(): void {
+		if (!this.root) {
+			return;
+		}
+
+		const focusedTabId = this.getFocusedTabId();
+		this.closeOpenMenu();
+		this.tabDisposables.clear();
+		this.contentDisposables.clear();
+		this.overlay?.close();
+		this.overlay = undefined;
+		for (const button of this.tabButtons) {
+			button.remove();
+		}
+		this.tabButtons = [];
+
+		const tabs = this.visibleTabs();
+		const active = this.ensureActiveTab(tabs);
+		for (const tab of tabs) {
+			const button = this.tabList.ownerDocument.createElement('button');
+			button.type = 'button';
+			button.className = 'ribbon-tab';
+			button.textContent = tab.title;
+			button.dataset.tabId = tab.id;
+			button.setAttribute('role', 'tab');
+			button.setAttribute('aria-selected', String(tab === active));
+			button.tabIndex = tab === active ? 0 : -1;
+			this.tabList.insertBefore(button, this.collapseButton);
+			this.tabButtons.push(button);
+			this.tabDisposables.add(addDisposableListener(button, EventType.CLICK, () => this.selectTab(tab)));
+			this.tabDisposables.add(addDisposableListener(button, EventType.DBLCLICK, () => this.setCollapsed(!this.collapsed)));
+		}
+
+		this.collapseButton.className = `ribbon-collapse codicon codicon-chevron-${this.collapsed ? 'down' : 'up'}`;
+		this.collapseButton.setAttribute('aria-label', this.collapsed ? localize('ribbon.expand', "Expand Ribbon") : localize('ribbon.collapse', "Collapse Ribbon"));
+		this.root.classList.toggle('collapsed', this.collapsed);
+		this.content.hidden = this.collapsed;
+		this.renderActiveContent(active);
+		this.findTabButton(focusedTabId)?.focus();
+	}
+
+	private selectTab(tab: RibbonTab): void {
+		this.activeTabId = tab.id;
+		this.hasPersistedActiveTab = true;
+		this.storageService.store(STORAGE_ACTIVE_TAB, tab.id, StorageScope.PROFILE, StorageTarget.USER);
+		for (const button of this.tabButtons) {
+			const selected = button.dataset.tabId === tab.id;
+			button.setAttribute('aria-selected', String(selected));
+			button.tabIndex = selected ? 0 : -1;
+		}
+		if (this.collapsed) {
+			this.showOverlay(tab);
+		} else {
+			this.renderActiveContent(tab);
+		}
+	}
+
+	private renderActiveContent(tab: RibbonTab | undefined): void {
+		this.closeOpenMenu();
+		this.contentDisposables.clear();
+		if (tab && !this.collapsed) {
+			this.renderTabContent(tab, this.content, false);
+		} else {
+			clearNode(this.content);
+		}
+	}
+
+	private refreshActiveContent(): void {
+		if (!this.root) {
+			return;
+		}
+		const active = this.ensureActiveTab(this.visibleTabs());
+		if (this.collapsed) {
+			this.closeOpenMenu();
+			if (active && this.overlay) {
+				this.showOverlay(active);
+			}
+		} else {
+			this.renderActiveContent(active);
+		}
+	}
+
+	private getFocusedTabId(): string | undefined {
+		const activeElement = getWindow(this.tabList).document.activeElement;
+		return this.tabButtons.find(button => button === activeElement)?.dataset.tabId;
+	}
+
+	private findTabButton(id: string | undefined): HTMLButtonElement | undefined {
+		return this.tabButtons.find(button => button.dataset.tabId === id);
+	}
+
+	private setCollapsed(collapsed: boolean): void {
+		if (this.collapsed === collapsed) {
+			return;
+		}
+		this.collapsed = collapsed;
+		this.storageService.store(STORAGE_COLLAPSED, collapsed, StorageScope.PROFILE, StorageTarget.USER);
+		this.render();
+		this._onDidChange.fire(undefined);
+	}
+
+	private showOverlay(tab: RibbonTab): void {
+		this.overlay?.close();
+		this.closeOpenMenu();
+		let firstFocusableButton: HTMLButtonElement | undefined;
+		const open = this.contextViewService.showContextView({
+			getAnchor: () => this.root,
+			render: container => {
+				container.classList.add('ribbon-overlay');
+				container.style.width = `${this.dimension?.width ?? this.root.clientWidth}px`;
+				const store = new DisposableStore();
+				store.add(addDisposableListener(getWindow(this.root).document, EventType.MOUSE_DOWN, event => {
+					const eventTarget = event.target as Node | null;
+					if (!isAncestor(eventTarget, container) && !isAncestor(eventTarget, this.root)) {
+						this.contextViewService.hideContextView();
+					}
+				}, true));
+				firstFocusableButton = this.renderTabContent(tab, container, true, store);
+				return store;
+			},
+			focus: () => firstFocusableButton?.focus(),
+			onHide: () => { this.overlay = undefined; },
+		});
+		this.overlay = open;
+	}
