+const BUILTIN_TABS: readonly IBuiltinRibbonTab[] = [
+	{ id: RibbonBuiltinTabId.File, title: localize('ribbon.file', "File"), order: 10, menuId: MenuId.MenubarFileMenu },
+	{ id: RibbonBuiltinTabId.View, title: localize('ribbon.view', "View"), order: 20, menuId: MenuId.MenubarViewMenu },
