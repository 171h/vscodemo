+	private renderContributionGroupDropdown(parent: HTMLElement, tab: IRegisteredRibbonTab, contribution: IRibbonGroupContribution, store: DisposableStore): void {
+		const button = append(parent, $<HTMLButtonElement>('button.ribbon-group-dropdown'));
+		button.type = 'button';
+		button.setAttribute('aria-label', localize('ribbon.openGroup', "Open {0} menu", contribution.title));
+		button.dataset.menuId = `group:${contribution.id}`;
+		const representativeItem = contribution.items.find(item => this.matches(item.when)) ?? contribution.items[0];
+		this.renderContributionIcon(append(button, $('.ribbon-group-dropdown-icon')), tab, representativeItem);
+		append(button, $('span.ribbon-group-dropdown-label')).textContent = contribution.title;
+		append(button, $('.ribbon-group-dropdown-chevron.codicon.codicon-chevron-down'));
+		store.add(addDisposableListener(button, EventType.CLICK, () => {
+			this.showContributionMenu(button, tab, { items: contribution.items, layout: contribution.menu?.layout });
+		}));
+	}
+
+	private renderGroupDropdown(parent: HTMLElement, tab: IBuiltinRibbonTab, title: string, actions: readonly IAction[], store: DisposableStore): void {
+		const button = append(parent, $<HTMLButtonElement>('button.ribbon-group-dropdown'));
+		button.type = 'button';
+		button.setAttribute('aria-label', localize('ribbon.openGroup', "Open {0} menu", title));
+		this.renderBuiltinActionIcon(append(button, $('.ribbon-group-dropdown-icon')), tab, actions[0]);
+		append(button, $('span.ribbon-group-dropdown-label')).textContent = title;
+		append(button, $('.ribbon-group-dropdown-chevron.codicon.codicon-chevron-down'));
+		store.add(addDisposableListener(button, EventType.CLICK, () => {
+			/*
+			 * 内置 tab 折叠下拉走 IContextMenuService（同样基于 ContextView 单
+			 * 例）。点同一个按钮 → toggle；点其他下拉 → 先收旧再弹新，避免出
+			 * 现"旧的收了、新的没弹"。
+			 */
+			if (this.openMenuKind === 'contextMenu' && this.openMenuAnchor === button) {
+				this.closeOpenMenu();
+				return;
+			}
+			this.closeOpenMenu();
+			this.openMenuAnchor = button;
+			this.openMenuId = `builtin:${tab.id}:${title}`;
+			this.openMenuKind = 'contextMenu';
+			this.contextMenuService.showContextMenu({
+				getAnchor: () => button,
+				getActions: () => [...actions],
+				onHide: () => {
+					if (this.openMenuAnchor === button) {
+						this.openMenuAnchor = undefined;
+						this.openMenuId = undefined;
+						this.openMenuKind = undefined;
+					}
+				},
+			});
+		}));
+	}
+
+	private installResponsiveOverflow(container: HTMLElement, viewport: HTMLElement, groups: HTMLElement, collapsibleGroups: readonly HTMLElement[], store: DisposableStore): void {
+		const left = append(container, $<HTMLButtonElement>('button.ribbon-scroll-button.left.codicon.codicon-chevron-left'));
+		const right = append(container, $<HTMLButtonElement>('button.ribbon-scroll-button.right.codicon.codicon-chevron-right'));
+		left.type = right.type = 'button';
+		left.setAttribute('aria-label', localize('ribbon.scrollLeft', "Scroll Ribbon left"));
+		right.setAttribute('aria-label', localize('ribbon.scrollRight', "Scroll Ribbon right"));
+		left.hidden = right.hidden = true;
+
+		const updateScrollButtons = () => {
+			const maximum = Math.max(0, groups.scrollWidth - viewport.clientWidth);
+			left.hidden = maximum === 0 || viewport.scrollLeft <= 1;
+			right.hidden = maximum === 0 || viewport.scrollLeft >= maximum - 1;
+		};
+		const responsiveButtons = Array.from(groups.querySelectorAll<HTMLButtonElement>('.ribbon-item[data-responsive-layouts]'));
+		const responsiveMenus = Array.from(groups.querySelectorAll<HTMLElement>('.ribbon-responsive-menu'));
+		const responsiveMenuSources = Array.from(groups.querySelectorAll<HTMLElement>('[data-responsive-menu-source]'));
+		const fit = () => {
+			for (const group of collapsibleGroups) {
+				group.classList.remove('folded');
+			}
+			for (const button of responsiveButtons) {
+				this.applyButtonLayout(button, button.dataset.ribbonSize as RibbonItemSize, button.dataset.ribbonStyle as RibbonItemStyle);
+				button.dataset.responsiveIndex = '-1';
+			}
+			for (const source of responsiveMenuSources) {
+				source.hidden = false;
+			}
+			for (const menu of responsiveMenus) {
+				menu.hidden = true;
+			}
+			viewport.scrollLeft = 0;
+
+			let changed = true;
+			while (groups.scrollWidth > viewport.clientWidth && changed) {
+				changed = false;
+				for (const button of responsiveButtons) {
+					const layouts = JSON.parse(button.dataset.responsiveLayouts ?? '[]') as IRibbonResponsiveLayoutContribution[];
+					const next = Number(button.dataset.responsiveIndex ?? '-1') + 1;
+					const layout = layouts[next];
+					if (!layout) {
+						continue;
+					}
+					this.applyButtonLayout(button, layout.size, layout.style);
+					button.dataset.responsiveIndex = String(next);
+					changed = true;
+					if (groups.scrollWidth <= viewport.clientWidth) {
+						break;
+					}
+				}
+			}
+
+			for (const menu of responsiveMenus) {
+				if (groups.scrollWidth <= viewport.clientWidth) {
+					break;
+				}
+				for (const source of responsiveMenuSources) {
+					if (source.dataset.responsiveMenuSource === menu.dataset.responsiveMenuId) {
+						source.hidden = true;
+					}
+				}
+				menu.hidden = false;
+			}
+
+			for (let index = collapsibleGroups.length - 1; groups.scrollWidth > viewport.clientWidth && index >= 0; index--) {
+				collapsibleGroups[index].classList.add('folded');
+			}
+			updateScrollButtons();
+		};
+		const scroll = (direction: -1 | 1) => {
+			viewport.scrollLeft += direction * Math.max(80, Math.floor(viewport.clientWidth * 0.8));
+			updateScrollButtons();
+		};
+
+		store.add(addDisposableListener(left, EventType.CLICK, () => scroll(-1)));
+		store.add(addDisposableListener(right, EventType.CLICK, () => scroll(1)));
+		store.add(addDisposableListener(viewport, EventType.SCROLL, updateScrollButtons));
+		store.add(addDisposableListener(getWindow(container), EventType.RESIZE, fit));
+		const ResizeObserverCtor = getWindow(container).ResizeObserver;
+		if (ResizeObserverCtor) {
+			const observer = new ResizeObserverCtor(fit);
+			observer.observe(container);
+			store.add({ dispose: () => observer.disconnect() });
+		}
+		fit();
+	}
+
+	private renderContributionItem(parent: HTMLElement, tab: IRegisteredRibbonTab, item: IRibbonItemContribution, closeAfterRun: boolean, store: DisposableStore, openNestedMenu?: (menu: IRibbonMenuContribution) => void): HTMLButtonElement {
+		const type = item.type ?? 'button';
+		const enabled = this.isContributionCommandEnabled(item.command);
+		const openMenu = (anchor: HTMLElement) => {
+			if (!item.menu) {
+				return;
+			}
+			if (openNestedMenu) {
+				openNestedMenu(item.menu);
+			} else {
+				this.showContributionMenu(anchor, tab, item.menu);
+			}
+		};
+
+		if (type === 'button') {
+			const { button, icon } = this.createButton(parent, item.title, enabled, item.size, item.style, item.responsive);
+			this.renderContributionIcon(icon, tab, item);
+			store.add(addDisposableListener(button, EventType.CLICK, () => this.runContributionCommand(item, closeAfterRun)));
+			return button;
+		}
+
+		if (type === 'splitButton') {
+			const split = append(parent, $('.ribbon-dropdown-item.ribbon-item-full'));
+			split.setAttribute('role', 'group');
+			split.setAttribute('aria-label', item.title);
+			const primary = append(split, $<HTMLButtonElement>('button.ribbon-dropdown-primary'));
+			primary.type = 'button';
+			primary.disabled = !enabled;
+			primary.setAttribute('aria-label', localize('ribbon.runCommand', "Run {0}", item.title));
+			this.renderContributionIcon(append(primary, $('.ribbon-item-icon')), tab, item);
+			const trigger = this.createDropdownTrigger(split, item.title, store);
+			trigger.dataset.menuId = `item:${item.title}`;
+			store.add(addDisposableListener(primary, EventType.CLICK, () => this.runContributionCommand(item, closeAfterRun)));
+			store.add(addDisposableListener(trigger, EventType.CLICK, () => openMenu(trigger)));
+			return enabled ? primary : trigger;
+		}
+
+		const button = append(parent, $<HTMLButtonElement>('button.ribbon-dropdown-item.ribbon-item-full.ribbon-dropdown-single'));
+		button.type = 'button';
+		button.setAttribute('aria-label', localize('ribbon.openItemMenu', "Open {0} menu", item.title));
+		button.setAttribute('aria-haspopup', 'dialog');
+		button.dataset.menuId = `item:${item.title}`;
+		this.renderContributionIcon(append(button, $('.ribbon-item-icon')), tab, item);
+		const footer = append(button, $('.ribbon-dropdown-footer'));
+		append(footer, $('span.ribbon-item-label')).textContent = item.title;
+		append(footer, $('.codicon.codicon-chevron-down'));
+		this.watchRibbonLabelLines(footer, store);
+		store.add(addDisposableListener(button, EventType.CLICK, () => openMenu(button)));
+		return button;
+	}
+
+	private createDropdownTrigger(parent: HTMLElement, title: string, store: DisposableStore): HTMLButtonElement {
+		const trigger = append(parent, $<HTMLButtonElement>('button.ribbon-dropdown-trigger'));
+		trigger.type = 'button';
+		trigger.setAttribute('aria-label', localize('ribbon.openItemMenu', "Open {0} menu", title));
+		trigger.setAttribute('aria-haspopup', 'dialog');
+		append(trigger, $('span.ribbon-item-label')).textContent = title;
+		append(trigger, $('.codicon.codicon-chevron-down'));
+		this.watchRibbonLabelLines(trigger, store);
+		return trigger;
+	}
+
+	/*
+	 * Toggles `ribbon-label-single` / `ribbon-label-double` on a dropdown trigger
+	 * or footer based on whether its label wraps to a second line at the current
+	 * layout. Recomputes on resize via ResizeObserver so the chevron keeps its
+	 * horizontal alignment as the group width changes.
+	 */
+	private watchRibbonLabelLines(container: HTMLElement, store: DisposableStore): void {
+		const label = container.querySelector<HTMLElement>('.ribbon-item-label');
+		if (!label) {
+			return;
+		}
+		const apply = () => {
+			const isDoubleLine = label.offsetHeight > 15;
+			container.classList.toggle('ribbon-label-single', !isDoubleLine);
+			container.classList.toggle('ribbon-label-double', isDoubleLine);
+		};
+		apply();
+		store.add(addDisposableListener(getWindow(container), EventType.RESIZE, apply));
+		const ResizeObserverCtor = getWindow(container).ResizeObserver;
+		if (ResizeObserverCtor) {
+			const observer = new ResizeObserverCtor(apply);
+			observer.observe(label);
+			store.add({ dispose: () => observer.disconnect() });
+		}
+	}
+
+	private isContributionCommandEnabled(commandId: string | undefined): boolean {
+		if (!commandId) {
+			return false;
+		}
+		const command = MenuRegistry.getCommand(commandId);
+		return !command?.precondition || this.contextKeyService.contextMatchesRules(command.precondition);
+	}
+
+	private runContributionCommand(item: IRibbonItemContribution, closeAfterRun: boolean): void {
+		if (!item.command) {
+			return;
+		}
+		void this.commandService.executeCommand(item.command, ...(item.arguments ?? [])).catch(error => this.notificationService.error(error));
+		if (closeAfterRun) {
+			this.contextViewService.hideContextView();
+		}
+	}
+
+	private renderContributionIcon(icon: HTMLElement, tab: IRegisteredRibbonTab, item: IRibbonItemContribution): void {
+		const iconValue = typeof item.icon === 'string' ? item.icon : isDark(this.themeService.getColorTheme().type) ? item.icon.dark : item.icon.light;
+		const themeIcon = ThemeIcon.fromString(iconValue);
+		if (themeIcon) {
+			icon.classList.add(...ThemeIcon.asClassNameArray(themeIcon));
+		} else {
+			icon.style.backgroundImage = asCSSUrl(resources.joinPath(tab.extensionLocation, iconValue));
+			icon.classList.add('ribbon-file-icon');
+		}
+	}
+
+	private showContributionMenu(anchor: HTMLElement, tab: IRegisteredRibbonTab, menu: IRibbonMenuContribution | undefined): void {
+		if (!menu) {
+			return;
+		}
+		/*
+		 * 切换语义：如果点击的 anchor 就是当前已打开的扩展菜单的 anchor，先收起再
+		 * 返回（toggle）；否则先把旧 view 关掉再 show，确保切换时新菜单一定会弹
+		 * 出来，避免上游 ContextView 在 anchor 被销毁时静默吞掉新的 show 调用。
+		 */
+		const menuId = `contribution:${tab.id}:${anchor.dataset.menuId ?? ''}`;
+		if (this.openMenuKind === 'contextView' && this.openMenuAnchor === anchor) {
+			this.closeOpenMenu();
+			return;
+		}
+		this.closeOpenMenu();
+		this.openMenuAnchor = anchor;
+		this.openMenuId = menuId;
+		this.openMenuKind = 'contextView';
+		if (menu.layout === 'panel') {
+			/*
+			 * 面板布局：复用 IRibbonService.showPanelDropdown 公共入口，把声明
+			 * 式 items / custom 转成结构化描述符；渲染时通过 renderItem 回调
+			 * 复用 renderContributionItem（继承图标解析、命令执行、when 过滤）。
+			 * panelStore 跟随面板生命周期，面板关闭时一并释放。renderItem 回调
+			 * 的 item 形参在描述符层面泛化为 IRibbonPanelItem，但声明式场景下
+			 * 实际传入的恒为 IRibbonItemContribution，故用 as 断言还原类型。
+			 */
+			const panelStore = new DisposableStore();
+			const descriptor: IRibbonPanelDescriptor = {
+				title: menu.title,
+				columns: menu.columns,
+				sections: menu.items?.length ? [{ items: menu.items.filter(item => this.matches(item.when)) }] : [],
+				custom: menu.custom,
+				renderItem: (parent, item) => this.renderContributionItem(parent, tab, item as IRibbonItemContribution, true, panelStore),
+			};
+			this.showPanelDropdown(anchor, descriptor, panelStore);
+			return;
+		}
+		let firstFocusableElement: HTMLElement | undefined;
+		const menuStack: IRibbonMenuContribution[] = [menu];
+		this.contextViewService.showContextView({
+			getAnchor: () => anchor,
+			render: container => {
+				container.classList.add('ribbon-item-menu');
+				const menuStore = new DisposableStore();
+				const contentStore = menuStore.add(new DisposableStore());
+				const renderCurrentMenu = (focus: boolean) => {
+					contentStore.clear();
+					clearNode(container);
+					firstFocusableElement = undefined;
+
+					if (menuStack.length > 1) {
+						const backButton = append(container, $<HTMLButtonElement>('button.ribbon-menu-back'));
+						backButton.type = 'button';
+						backButton.setAttribute('aria-label', localize('ribbon.menuBack', "Back to previous Ribbon menu"));
+						append(backButton, $('.codicon.codicon-arrow-left'));
+						append(backButton, $('span')).textContent = localize('ribbon.menuBackLabel', "Back");
+						contentStore.add(addDisposableListener(backButton, EventType.CLICK, () => {
+							menuStack.pop();
+							renderCurrentMenu(true);
+						}));
+						firstFocusableElement = backButton;
+					}
+
+					const currentMenu = menuStack[menuStack.length - 1];
+					if (currentMenu.items?.length) {
+						const items = append(container, $('.ribbon-menu-items'));
+						for (const item of currentMenu.items.filter(candidate => this.matches(candidate.when))) {
+							const button = this.renderContributionItem(items, tab, item, true, contentStore, nestedMenu => {
+								menuStack.push(nestedMenu);
+								renderCurrentMenu(true);
+							});
+							if (!button.disabled) {
+								firstFocusableElement ??= button;
+							}
+						}
+					}
+					if (currentMenu.custom) {
+						firstFocusableElement ??= this.renderCustomMenuContent(container, currentMenu.custom);
+					}
+					if (focus) {
+						firstFocusableElement?.focus();
+					}
+				};
+				renderCurrentMenu(false);
+				return menuStore;
+			},
+			focus: () => firstFocusableElement?.focus(),
+			onHide: () => {
+				if (this.openMenuAnchor === anchor) {
+					this.openMenuAnchor = undefined;
+					this.openMenuId = undefined;
+					this.openMenuKind = undefined;
+				}
+			},
+		});
+	}
+
+	/*
+	 * 主动收起当前打开的下拉菜单（折叠分组下拉 / 扩展面板下拉 / 内置 tab 折叠
+	 * 下拉）。三类都最终走 ContextView 单例，hideContextView() 会把它们一并收
+	 * 起。状态字段一并清空，方便下次 show 时的 toggle 判定从干净状态出发。
+	 */
+	private closeOpenMenu(): void {
+		if (this.openMenuKind === 'contextView' || this.openMenuKind === 'contextMenu') {
+			this.contextViewService.hideContextView();
+		}
+		this.openMenuAnchor = undefined;
+		this.openMenuId = undefined;
+		this.openMenuKind = undefined;
+	}
+
+	/*
+	 * Word 风格面板下拉的统一实现。声明式 contributes.ribbon（layout:'panel'）
+	 * 和运行时 IRibbonService.showPanelDropdown 都走这里。
+	 *
+	 * 结构：
+	 *   .ribbon-panel-dropdown            ← 外壳（边框/阴影/色板）
+	 *   ├── .ribbon-panel-header?          ← 可选标题栏（含关闭按钮）
+	 *   ├── .ribbon-panel-body            ← 主体（sections + custom）
+	 *   │   ├── .ribbon-panel-section?     ← 每个 section
+	 *   │   │   ├── .ribbon-panel-section-title?
+	 *   │   │   └── .ribbon-panel-grid     ← 网格容器（columns 控制列数）
+	 *   │   │       └── .ribbon-panel-cell ← 单格（大图标 + label）
+	 *   │   └── iframe.ribbon-custom-content?
+	 *   └── .ribbon-panel-footer?          ← 预留（当前未渲染）
+	 *
+	 * 与竖排菜单的区别：使用 --vscode-ribbon-dropdown-* 专用色板，不依赖
+	 * --vscode-menu-*，避免观感被误认为"菜单栏"。
+	 */
+	showPanelDropdown(anchor: HTMLElement, descriptor: IRibbonPanelDescriptor, externalStore?: DisposableStore): IRibbonPanelHandle {
+		this.closeOpenMenu();
+		this.openMenuAnchor = anchor;
+		this.openMenuId = `panel:${descriptor.title ?? ''}`;
+		this.openMenuKind = 'contextView';
+		const panelStore = externalStore ?? new DisposableStore();
+		const columns = Math.min(8, Math.max(1, descriptor.columns ?? 3));
+		let firstFocusableElement: HTMLElement | undefined;
+		this.contextViewService.showContextView({
+			getAnchor: () => anchor,
+			render: container => {
+				container.classList.add('ribbon-panel-dropdown');
+				container.style.setProperty('--ribbon-panel-columns', String(columns));
+				clearNode(container);
+
+				if (descriptor.title) {
+					const header = append(container, $('.ribbon-panel-header'));
+					append(header, $('span.ribbon-panel-title')).textContent = descriptor.title;
+					const closeButton = append(header, $<HTMLButtonElement>('button.ribbon-panel-close.codicon.codicon-close'));
+					closeButton.type = 'button';
+					closeButton.setAttribute('aria-label', localize('ribbon.panelClose', "Close Ribbon panel"));
+					panelStore.add(addDisposableListener(closeButton, EventType.CLICK, () => this.closeOpenMenu()));
+					firstFocusableElement = closeButton;
+				}
+
+				const body = append(container, $('.ribbon-panel-body'));
+				const sections = descriptor.sections ?? [];
+				for (const section of sections) {
+					const sectionEl = append(body, $('.ribbon-panel-section'));
+					if (section.title) {
+						append(sectionEl, $('.ribbon-panel-section-title')).textContent = section.title;
+					}
+					if (section.items.length === 0) {
+						continue;
+					}
+					const grid = append(sectionEl, $('.ribbon-panel-grid'));
+					for (const item of section.items) {
+						let cell: HTMLElement;
+						if (descriptor.renderItem) {
+							cell = descriptor.renderItem(grid, item);
+						} else {
+							cell = this.renderDefaultPanelCell(grid, item, panelStore);
+						}
+						cell.classList.add('ribbon-panel-cell');
+						if (!cell.hasAttribute('tabindex')) {
+							cell.setAttribute('tabindex', '0');
+						}
+						firstFocusableElement ??= cell as HTMLElement;
+					}
+				}
+
+				if (descriptor.custom) {
+					firstFocusableElement ??= this.renderCustomMenuContent(body, descriptor.custom);
+				}
+				return panelStore;
+			},
+			focus: () => firstFocusableElement?.focus(),
+			onHide: () => {
+				if (this.openMenuAnchor === anchor) {
+					this.openMenuAnchor = undefined;
+					this.openMenuId = undefined;
+					this.openMenuKind = undefined;
+				}
+			},
+		});
+		// ContextView 单例：handle.close 通过 closeOpenMenu 复用 hideContextView。
+		return {
+			close: () => {
+				if (this.openMenuAnchor === anchor) {
+					this.closeOpenMenu();
+				}
+			},
+		};
+	}
+
+	/*
+	 * 默认面板格子渲染：用于扩展运行时调用 showPanelDropdown 但未提供
+	 * renderItem 时。生成"大图标 + label"的 button，点击执行 command。声明
+	 * 式 contributes.ribbon 走 showContributionMenu → renderItem 回调，不会
+	 * 走到这里。
+	 */
+	private renderDefaultPanelCell(parent: HTMLElement, item: IRibbonPanelItem, panelStore: DisposableStore): HTMLButtonElement {
+		const button = append(parent, $<HTMLButtonElement>('button.ribbon-panel-cell-button'));
+		button.type = 'button';
+		button.setAttribute('aria-label', item.title);
+		const icon = append(button, $('.ribbon-panel-cell-icon'));
+		if (item.icon) {
+			const value = typeof item.icon === 'string' ? item.icon : item.icon.dark;
+			const themeIcon = ThemeIcon.fromString(value);
+			if (themeIcon) {
+				icon.classList.add(...ThemeIcon.asClassNameArray(themeIcon));
+			}
+		}
+		append(button, $('span.ribbon-panel-cell-label')).textContent = item.title;
+		button.disabled = !item.command;
+		if (item.command) {
+			panelStore.add(addDisposableListener(button, EventType.CLICK, () => {
+				void this.commandService.executeCommand(item.command!, ...(item.arguments ?? []))
+					.catch(error => this.notificationService.error(error));
+				this.closeOpenMenu();
+			}));
+		}
+		return button;
+	}
+
+	private renderCustomMenuContent(parent: HTMLElement, content: IRibbonCustomContentContribution): HTMLIFrameElement {
+		const frame = append(parent, $<HTMLIFrameElement>('iframe.ribbon-custom-content'));
+		frame.title = localize('ribbon.customContent', "Custom Ribbon menu content");
+		frame.setAttribute('sandbox', '');
+		frame.style.width = `${content.width ?? 360}px`;
+		frame.style.height = `${content.height ?? 280}px`;
+		frame.srcdoc = this.customFrameSource(content);
+		return frame;
+	}
+
+	private customFrameSource(content: IRibbonCustomContentContribution): string {
+		const css = (content.css ?? '').replace(/<\/style/gi, '<\\/style');
+		return `<!doctype html><html><head><meta charset="utf-8"><meta http-equiv="Content-Security-Policy" content="default-src 'none'; img-src data:; style-src 'unsafe-inline'; script-src 'none'; font-src data:"><style>html,body{box-sizing:border-box;margin:0;min-height:100%;font:13px sans-serif}${css}</style></head><body>${content.html}</body></html>`;
+	}
+
+	private createButton(parent: HTMLElement, label: string, enabled: boolean, size: RibbonItemSize = 'full', style: RibbonItemStyle = 'iconAndLabel', responsive: readonly IRibbonResponsiveLayoutContribution[] = []): { button: HTMLButtonElement; icon: HTMLElement } {
+		const button = append(parent, $<HTMLButtonElement>('button.ribbon-item'));
+		button.dataset.ribbonSize = size;
+		button.dataset.ribbonStyle = style;
+		if (responsive.length > 0) {
+			button.dataset.responsiveLayouts = JSON.stringify(responsive);
+			button.dataset.responsiveIndex = '-1';
+		}
+		button.type = 'button';
+		button.disabled = !enabled;
+		button.setAttribute('aria-label', label);
+		this.applyButtonLayout(button, size, style);
+		const icon = append(button, $('.ribbon-item-icon'));
+		append(button, $('span.ribbon-item-label')).textContent = label;
+		return { button, icon };
+	}
+
+	private applyButtonLayout(button: HTMLButtonElement, size: RibbonItemSize, style: RibbonItemStyle = 'iconAndLabel'): void {
+		const layout = size === 'full' ? 'vertical' : style === 'icon' ? 'icon-only' : 'horizontal';
+		for (const candidate of ['full', 'half', 'third']) {
+			button.classList.remove(`ribbon-item-${candidate}`);
+		}
+		for (const candidate of ['vertical', 'horizontal', 'icon-only']) {
+			button.classList.remove(`ribbon-item-${candidate}`);
+		}
+		button.classList.add(`ribbon-item-${size}`, `ribbon-item-${layout}`);
+		button.title = layout === 'icon-only' ? button.getAttribute('aria-label') ?? '' : '';
+	}
+
+	private onTabKeyDown(event: KeyboardEvent): void {
+		const tabs = this.tabButtons;
+		const current = tabs.indexOf(getWindow(this.tabList).document.activeElement as HTMLButtonElement);
+		if (current < 0) {
+			return;
+		}
+		let target = current;
+		if (event.key === 'ArrowRight') {
+			target = (current + 1) % tabs.length;
+		} else if (event.key === 'ArrowLeft') {
+			target = (current - 1 + tabs.length) % tabs.length;
+		} else if (event.key === 'Home') {
+			target = 0;
+		} else if (event.key === 'End') {
+			target = tabs.length - 1;
+		} else {
+			return;
+		}
+		event.preventDefault();
+		tabs[target].focus();
+		tabs[target].click();
+	}
+
+	focus(): void {
+		this.findTabButton(this.activeTabId)?.focus();
+	}
+
+	toJSON(): object {
+		return { type: Parts.RIBBON_PART };
+	}
+}
+
+registerSingleton(IRibbonService, RibbonPart, InstantiationType.Eager);
