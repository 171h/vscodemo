+	min-width: 220px;
+	max-width: min(720px, calc(100vw - 24px));
+	max-height: min(640px, calc(100vh - 24px));
+	overflow: auto;
+	background: var(--vscode-ribbon-dropdown-background);
+	color: var(--vscode-ribbon-dropdown-foreground);
+	border: 1px solid var(--vscode-ribbon-dropdown-border);
