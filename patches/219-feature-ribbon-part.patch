+.ribbon-dropdown-primary,
+.ribbon-dropdown-trigger,
+.ribbon-dropdown-single {
+	display: flex;
+	align-items: center;
+	justify-content: center;
+	width: 100%;
+	padding: 0 6px;
+	cursor: pointer;
+}
+
+.ribbon-dropdown-primary,
+.ribbon-dropdown-single {
+	flex: 0 0 auto;
+	flex-direction: column;
+	min-height: 0;
+}
+
+.ribbon-dropdown-primary .ribbon-item-icon,
