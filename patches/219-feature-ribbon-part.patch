+}
+
+.ribbon-panel-cell .ribbon-dropdown-footer,
+.ribbon-panel-cell .ribbon-dropdown-trigger {
+	flex-direction: column;
+	align-items: center;
+	gap: 2px;
+}
+
+.ribbon-panel-cell .ribbon-dropdown-footer .codicon,
+.ribbon-panel-cell .ribbon-dropdown-trigger .codicon {
+	font-size: 10px;
+}
+
+.ribbon-panel-dropdown .ribbon-custom-content {
+	display: block;
+	max-width: 100%;
+	border: 0;
+	background: transparent;
+}
