+	}
+
+	private createButton(parent: HTMLElement, label: string, iconClass: string | undefined, enabled: boolean): { button: HTMLButtonElement; icon: HTMLElement } {
+		const button = append(parent, $<HTMLButtonElement>('button.ribbon-item'));
