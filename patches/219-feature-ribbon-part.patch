+				container.classList.add('ribbon-file-icon');
+				return;
+			}
+		}
+
+		container.classList.add(...ThemeIcon.asClassNameArray(builtinActionFallbackIcon(tab, action)));
+	}
+
+	private renderContributionGroup(parent: HTMLElement, tab: IRegisteredRibbonTab, contribution: IRibbonGroupContribution, closeAfterRun: boolean, store: DisposableStore): HTMLButtonElement | undefined {
+		const group = append(parent, $('.ribbon-group'));
+		group.setAttribute('role', 'group');
+		group.setAttribute('aria-label', contribution.title);
+		const items = append(group, $('.ribbon-items'));
