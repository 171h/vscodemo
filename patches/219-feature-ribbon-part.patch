+	display: flex;
+	align-items: center;
+	gap: 6px;
+	width: 100%;
+	min-height: 30px;
+	padding: 4px 8px;
+	cursor: pointer;
+	border-bottom: 1px solid var(--vscode-menu-separatorBackground);
+}
+
+.ribbon-menu-items {
+	display: flex;
+	flex-direction: column;
+	gap: 2px;
+	padding: 4px;
+}
+
+.ribbon-menu-items > .ribbon-item {
+	min-height: 32px;
+	max-width: none;
+	justify-content: flex-start;
+	flex-direction: row;
+	gap: 6px;
+}
+
+.ribbon-menu-items > .ribbon-item .ribbon-item-icon {
+	width: 22px;
+	height: 22px;
+	font-size: 22px;
+}
+
+.ribbon-menu-items > .ribbon-dropdown-item {
+	min-width: 180px;
+	min-height: 74px;
+}
+
+.ribbon-custom-content {
+	display: block;
+	max-width: 100%;
+	border: 0;
+	background: transparent;
+}
+
+.ribbon-group-title {
+	height: 14px;
+	font-size: 10px;
+	line-height: 14px;
+	text-align: center;
+	color: var(--vscode-descriptionForeground);
+}
+
+.ribbon-root.collapsed .ribbon-tabs {
+	border-bottom: 0;
+}
