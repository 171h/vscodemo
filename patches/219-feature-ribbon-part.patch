+			tabIds.add(tab.id);
+			tabs.push({
+				...tab,
+				groups,
+				extensionId: extension.description.identifier.value,
+				extensionLocation: extension.description.extensionLocation,
+			});
+		}
+	}
+
+	tabs.sort((a, b) => orderOf(a) - orderOf(b) || a.extensionId.localeCompare(b.extensionId) || a.id.localeCompare(b.id));
+	ribbonRegistry.setTabs(tabs);
+});
