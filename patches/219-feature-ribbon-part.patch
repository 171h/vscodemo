+	private renderTabContent(tab: RibbonTab, container: HTMLElement, closeAfterRun: boolean, store: DisposableStore = this.contentDisposables): HTMLButtonElement | undefined {
+		clearNode(container);
+		container.setAttribute('aria-label', tab.title);
+		const viewport = append(container, $('.ribbon-scroll-viewport'));
+		const groups = append(viewport, $('.ribbon-groups'));
+		const collapsibleGroups: HTMLElement[] = [];
+
+		if (isBuiltinTab(tab)) {
+			const menu = store.add(this.menuService.createMenu(tab.menuId, this.contextKeyService, { emitEventsForSubmenuChanges: true }));
+			store.add(menu.onDidChange(() => {
+				if (closeAfterRun) {
+					if (this.collapsed && this.activeTabId === tab.id) {
+						this.showOverlay(tab);
+					}
+				} else if (!this.collapsed && this.activeTabId === tab.id) {
+					this.renderActiveContent(tab);
+				}
+			}));
+			let firstFocusableButton: HTMLButtonElement | undefined;
+			for (const [groupId, actions] of menu.getActions()) {
+				const candidate = this.renderActionGroup(groups, tab, groupId, actions, closeAfterRun, store, collapsibleGroups);
+				firstFocusableButton ??= candidate;
+			}
+			this.installResponsiveOverflow(container, viewport, groups, collapsibleGroups, store);
+			return firstFocusableButton;
+		}
+
+		let firstFocusableButton: HTMLButtonElement | undefined;
+		for (const group of tab.groups.filter(group => this.matches(group.when))) {
+			const candidate = this.renderContributionGroup(groups, tab, group, closeAfterRun, store, collapsibleGroups);
+			firstFocusableButton ??= candidate;
+		}
+		this.installResponsiveOverflow(container, viewport, groups, collapsibleGroups, store);
+		return firstFocusableButton;
+	}
