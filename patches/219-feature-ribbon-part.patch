+}
+
+.ribbon-panel-body {
+	display: flex;
+	flex-direction: column;
+	gap: 8px;
+	padding: 8px;
+}
+
+.ribbon-panel-section {
+	display: flex;
+	flex-direction: column;
+	gap: 4px;
+}
+
+.ribbon-panel-section + .ribbon-panel-section {
+	padding-top: 6px;
+	border-top: 1px solid var(--vscode-ribbon-dropdown-separator);
+}
+
+.ribbon-panel-section-title {
+	font-size: 10px;
+	line-height: 14px;
+	text-transform: uppercase;
+	letter-spacing: 0.05em;
