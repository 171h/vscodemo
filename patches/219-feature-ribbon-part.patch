+	 * 当前已打开的"分组折叠下拉 / 扩展面板下拉"状态。扩展 tab 走
+	 * IContextViewService（同一时刻仅一个 view），用 anchor 引用 + menuId 来
+	 * 实现 toggle；内置 tab 走 IContextMenuService（同样基于 ContextView 单
+	 * 例），只用 anchor 引用做 toggle 判定。selectTab/render 重建 DOM 前会
+	 * 调 hideContextView 并清空此状态，避免"旧的收了、新的没弹"。
+	 */
+	private openMenuAnchor: HTMLElement | undefined;
+	private openMenuId: string | undefined;
+	private openMenuKind: 'contextView' | 'contextMenu' | undefined;
+
+	constructor(
