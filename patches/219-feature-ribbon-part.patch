diff --git a/src/vs/workbench/browser/parts/ribbon/media/ribbonpart.css b/src/vs/workbench/browser/parts/ribbon/media/ribbonpart.css
new file mode 100644
index 0000000000000000000000000000000000000000..595d553faa13b35b251903437d26c19a5b2dc84b
--- /dev/null
+++ b/src/vs/workbench/browser/parts/ribbon/media/ribbonpart.css
@@ -0,0 +1,653 @@
+.monaco-workbench .part.ribbon {
+	background: var(--vscode-editor-background);
+	color: var(--vscode-foreground);
+	border-bottom: 1px solid var(--vscode-panel-border);
+}
+
+.ribbon-root {
+	display: flex;
+	flex-direction: column;
+	height: 100%;
+	min-width: 0;
+}
+
+.ribbon-tabs {
+	display: flex;
+	align-items: stretch;
+	height: 32px;
+	min-height: 32px;
+	padding-left: 6px;
+	border-bottom: 1px solid var(--vscode-panel-border);
+}
+
+.ribbon-tab,
+.ribbon-collapse,
+.ribbon-item,
+.ribbon-dropdown-item,
+.ribbon-dropdown-primary,
+.ribbon-dropdown-trigger,
+.ribbon-group-dropdown,
+.ribbon-menu-back,
+.ribbon-scroll-button {
+	border: 0;
+	color: inherit;
+	background: transparent;
+	font: inherit;
+}
+
+.ribbon-tab {
+	position: relative;
+	padding: 0 12px;
+	cursor: pointer;
+}
+
+.ribbon-tab:hover,
+.ribbon-item:hover:not(:disabled),
+.ribbon-dropdown-item:hover,
+.ribbon-dropdown-primary:hover:not(:disabled),
+.ribbon-dropdown-trigger:hover,
+.ribbon-collapse:hover,
+.ribbon-group-dropdown:hover,
+.ribbon-menu-back:hover,
+.ribbon-scroll-button:hover {
+	background: var(--vscode-toolbar-hoverBackground);
+}
+
+.ribbon-tab[aria-selected="true"]::after {
+	position: absolute;
+	right: 8px;
+	bottom: 0;
+	left: 8px;
+	height: 2px;
+	content: '';
+	background: var(--vscode-focusBorder);
+}
+
+.ribbon-tab:focus-visible,
+.ribbon-item:focus-visible,
+.ribbon-dropdown-item:focus-visible,
+.ribbon-dropdown-primary:focus-visible,
+.ribbon-dropdown-trigger:focus-visible,
+.ribbon-collapse:focus-visible,
+.ribbon-group-dropdown:focus-visible,
+.ribbon-menu-back:focus-visible,
+.ribbon-scroll-button:focus-visible {
+	outline: 1px solid var(--vscode-focusBorder);
+	outline-offset: -1px;
+}
+
+.ribbon-collapse {
+	width: 32px;
+	margin-left: auto;
+	cursor: pointer;
+}
+
+.ribbon-content,
+.ribbon-overlay {
+	position: relative;
+	height: 98px;
+	box-sizing: border-box;
+	overflow: hidden;
+	background: var(--vscode-editor-background);
+	color: var(--vscode-foreground);
+	box-shadow: 0 4px 8px var(--vscode-widget-shadow);
+}
+
+.ribbon-scroll-viewport {
+	width: 100%;
+	height: 100%;
+	overflow: hidden;
+}
+
+.ribbon-groups {
+	display: flex;
+	align-items: stretch;
+	height: 100%;
+	width: max-content;
+	min-width: 100%;
+	padding: 3px 6px 2px;
+	box-sizing: border-box;
+}
+
+.ribbon-group {
+	display: flex;
+	--ribbon-item-full-height: 74px;
+	flex-direction: column;
+	min-width: max-content;
+	padding: 0 6px;
+	border-right: 1px solid var(--vscode-panel-border);
+}
+
+.ribbon-group-dropdown {
+	display: none;
+	flex-direction: column;
+	align-items: center;
+	justify-content: center;
+	gap: 0;
+	height: 100%;
+	min-width: 72px;
+	max-width: 112px;
+	padding: 2px 8px;
+	box-sizing: border-box;
+	cursor: pointer;
+}
+
+.ribbon-group-dropdown-icon {
+	--ribbon-icon-size: calc(var(--ribbon-item-full-height) - 11px);
+	display: flex;
+	flex: 1 1 0;
+	align-items: center;
+	justify-content: center;
+	width: 100%;
+	min-height: 0;
+	font-size: var(--ribbon-icon-size);
+	line-height: 1;
+	background-position: center;
+	background-repeat: no-repeat;
+	background-size: contain;
+}
+
+.ribbon-group-dropdown-label {
+	flex: 0 0 auto;
+	max-width: 100%;
+	overflow: hidden;
+	font-size: 11px;
+	line-height: 14px;
+	text-overflow: ellipsis;
+	white-space: nowrap;
+}
+
+.ribbon-group-dropdown-chevron {
+	flex: 0 0 12px;
+	height: 12px;
+	font-size: 12px;
+	line-height: 12px;
+}
+
+.ribbon-group.folded .ribbon-items,
+.ribbon-group.folded .ribbon-group-title {
+	display: none;
+}
+
+.ribbon-group.folded .ribbon-group-dropdown {
+	display: flex;
+}
+
+.ribbon-scroll-button {
+	position: absolute;
+	top: 0;
+	z-index: 1;
+	width: 32px;
+	height: 100%;
+	padding: 0;
+	font-size: 18px;
+	cursor: pointer;
+	background: var(--vscode-editor-background);
+	box-shadow: 0 0 8px var(--vscode-widget-shadow);
+}
+
+.ribbon-scroll-button[hidden] {
+	display: none;
+}
+
+.ribbon-scroll-button.left {
+	left: 0;
+}
+
+.ribbon-scroll-button.right {
+	right: 0;
+}
+
+/* Six tracks let full, half, and third-height buttons share a group. */
+.ribbon-items {
+	display: grid;
+	grid-template-rows: repeat(6, minmax(0, 1fr));
+	grid-auto-flow: column;
+	grid-auto-columns: max-content;
+	gap: 2px;
+	height: var(--ribbon-item-full-height);
+}
+
+.ribbon-item {
+	display: flex;
+	align-items: center;
+	justify-content: center;
+	min-width: 30px;
+	max-width: 150px;
+	padding: 2px 6px;
+	border-radius: 2px;
+	cursor: pointer;
+}
+
+.ribbon-item-full {
+	grid-row: span 6;
+}
+
+.ribbon-item-half {
+	grid-row: span 3;
+}
+
+.ribbon-item-third {
+	grid-row: span 2;
+}
+
+.ribbon-item-vertical {
+	flex-direction: column;
+	justify-content: flex-start;
+	min-width: 62px;
+	max-width: 118px;
+	padding-right: 2px;
+	padding-left: 2px;
+}
+
+.ribbon-item-horizontal {
+	flex-direction: row;
+	justify-content: flex-start;
+	gap: 5px;
+}
+
+.ribbon-item-icon-only {
+	padding-right: 4px;
+	padding-left: 4px;
+}
+
+.ribbon-items.compact .ribbon-item {
+	min-width: auto;
+	max-width: 150px;
+}
+
+.ribbon-item:disabled {
+	opacity: .45;
+	cursor: default;
+}
+
+.ribbon-item-icon {
+	--ribbon-icon-size: 18px;
+	display: flex;
+	align-items: center;
+	justify-content: center;
+	flex: 0 0 auto;
+	width: 18px;
+	height: 18px;
+	font-size: var(--ribbon-icon-size);
+	line-height: 1;
+	background-position: center;
+	background-repeat: no-repeat;
+	background-size: contain;
+}
+
+.ribbon-item-vertical .ribbon-item-icon {
+	--ribbon-icon-size: 40px;
+	flex: 0 0 auto;
+	width: 40px;
+	height: 40px;
+}
+
+.ribbon-item-half .ribbon-item-icon {
+	--ribbon-icon-size: 22px;
+	width: 22px;
+	height: 22px;
+}
+
+/*
+ * Codicon glyphs are clamped to 16px by two layers of upstream rules:
+ *   1) `.codicon[class*='codicon-'] { font: 16px/1 codicon }` (shorthand, specificity 0,2,0)
+ *   2) `.monaco-workbench .part .codicon[class*='codicon-'] { font-size: calc(...) }` (specificity 0,4,0)
+ * The (0,4,0) rule wins over the previous `.ribbon-root .ribbon-item-icon.codicon` (0,3,0) override,
+ * so the responsive icon size never took effect. Anchor the override on `.monaco-workbench .part.ribbon`
+ * (and the workbench-level overlay container) to push specificity past 0,4,0.
+ */
+.monaco-workbench .part.ribbon .ribbon-root .ribbon-item-icon.codicon,
+.monaco-workbench .part.ribbon .ribbon-root .ribbon-group-dropdown-icon.codicon,
+.monaco-workbench .ribbon-overlay .ribbon-item-icon.codicon,
+.monaco-workbench .ribbon-overlay .ribbon-group-dropdown-icon.codicon {
+	font-size: var(--ribbon-icon-size);
+}
+
+.ribbon-item-label {
+	max-width: 110px;
+	overflow: hidden;
+	font-size: 11px;
+	line-height: 15px;
+	text-align: center;
+	text-overflow: ellipsis;
+	white-space: nowrap;
+}
+
+.ribbon-item-icon-only .ribbon-item-label {
+	display: none;
+}
+
+.ribbon-dropdown-item {
+	display: flex;
+	flex-direction: column;
+	justify-content: flex-start;
+	min-width: 68px;
+	max-width: 128px;
+	padding: 0;
+	border-radius: 2px;
+	overflow: hidden;
+}
