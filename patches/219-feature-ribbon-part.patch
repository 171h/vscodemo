diff --git a/src/vs/workbench/test/browser/parts/ribbon/ribbonPart.test.ts b/src/vs/workbench/test/browser/parts/ribbon/ribbonPart.test.ts
new file mode 100644
index 0000000000000000000000000000000000000000..a0f49739c6fa0656f1fb391730c09e7869a331d5
--- /dev/null
+++ b/src/vs/workbench/test/browser/parts/ribbon/ribbonPart.test.ts
@@ -0,0 +1,201 @@
+/*---------------------------------------------------------------------------------------------
+ *  Copyright (c) Microsoft Corporation. All rights reserved.
+ *  Licensed under the MIT License. See License.txt in the project root for license information.
+ *--------------------------------------------------------------------------------------------*/
+
+import assert from 'assert';
+import { Action, IAction } from '../../../../../base/common/actions.js';
+import { Event } from '../../../../../base/common/event.js';
+import { DisposableStore, IDisposable } from '../../../../../base/common/lifecycle.js';
+import { URI } from '../../../../../base/common/uri.js';
+import { mainWindow } from '../../../../../base/browser/window.js';
+import { ensureNoDisposablesAreLeakedInTestSuite } from '../../../../../base/test/common/utils.js';
+import { IMenuService } from '../../../../../platform/actions/common/actions.js';
+import { ICommandService } from '../../../../../platform/commands/common/commands.js';
+import { ContextKeyService } from '../../../../../platform/contextkey/browser/contextKeyService.js';
+import { IContextMenuService, IContextViewDelegate, IContextViewService } from '../../../../../platform/contextview/browser/contextView.js';
+import { INotificationService } from '../../../../../platform/notification/common/notification.js';
+import { TestConfigurationService } from '../../../../../platform/configuration/test/common/testConfigurationService.js';
+import { ColorScheme } from '../../../../../platform/theme/common/theme.js';
+import { TestColorTheme, TestThemeService } from '../../../../../platform/theme/test/common/testThemeService.js';
+import { TestStorageService } from '../../../common/workbenchTestServices.js';
+import { TestLayoutService } from '../../workbenchTestServices.js';
+import { IRegisteredRibbonTab, isReservedRibbonTabId, RibbonBuiltinTabId, ribbonRegistry } from '../../../../browser/parts/ribbon/ribbonExtensionPoint.js';
+import { RibbonPart } from '../../../../browser/parts/ribbon/ribbonPart.js';
+
+suite('RibbonPart', () => {
+	const disposables = new DisposableStore();
+	let fixture: HTMLElement;
+
+	setup(() => {
+		fixture = mainWindow.document.createElement('div');
+		mainWindow.document.body.appendChild(fixture);
+		ribbonRegistry.setTabs([]);
+	});
+
+	teardown(() => {
+		disposables.clear();
+		ribbonRegistry.setTabs([]);
+		fixture.remove();
+	});
+
+	function contribution(overrides: Partial<IRegisteredRibbonTab> = {}): IRegisteredRibbonTab {
+		return {
+			id: 'test.ribbon.tab',
+			title: 'Test',
+			default: true,
+			groups: [{
+				id: 'test',
+				title: 'Test',
+				items: [{
+					command: 'test.ribbon.command',
+					title: 'Test command',
+					icon: '$(add)',
+				}],
+			}],
+			extensionId: 'test.ribbon',
+			extensionLocation: URI.file('/test-extension'),
+			...overrides,
+		};
+	}
+
+	function createPart(themeService = new TestThemeService(), contextKeyService = disposables.add(new ContextKeyService(new TestConfigurationService())), menuActions: readonly IAction[] = [], contextViewService = {} as IContextViewService): RibbonPart {
+		const menuService = {
+			createMenu: () => ({
+				onDidChange: Event.None,
+				getActions: () => menuActions.length > 0 ? [['navigation', menuActions]] : [],
+				dispose: () => { },
+			}),
+		} as unknown as IMenuService;
+		const part = disposables.add(new RibbonPart(
+			themeService,
+			disposables.add(new TestStorageService()),
+			new TestLayoutService(),
+			contextKeyService,
+			menuService,
+			{} as ICommandService,
+			{} as IContextMenuService,
+			contextViewService,
+			{} as INotificationService,
+		));
+		part.create(fixture);
+		return part;
+	}
+
+	function tab(id: string): HTMLButtonElement | undefined {
+		return Array.from(fixture.getElementsByClassName('ribbon-tab')).find(element => (element as HTMLButtonElement).dataset.tabId === id) as HTMLButtonElement | undefined;
+	}
+
+	function fileIcon(): HTMLElement {
+		return fixture.getElementsByClassName('ribbon-file-icon').item(0) as HTMLElement;
+	}
+
+	test('keeps keyboard focus while selecting tabs and supports double click collapse', () => {
+		const part = createPart();
+		const fileTab = tab(RibbonBuiltinTabId.File)!;
+		const viewTab = tab(RibbonBuiltinTabId.View)!;
+		fileTab.focus();
+
+		fileTab.dispatchEvent(new mainWindow.KeyboardEvent('keydown', { key: 'ArrowRight', bubbles: true }));
+
+		assert.strictEqual(mainWindow.document.activeElement, viewTab);
+		assert.strictEqual(viewTab.getAttribute('aria-selected'), 'true');
+		assert.strictEqual(viewTab.isConnected, true);
+
+		viewTab.dispatchEvent(new mainWindow.MouseEvent('dblclick', { bubbles: true }));
+		assert.strictEqual(part.minimumHeight, 32);
+	});
+
+	test('renders fallback icons and removes menubar mnemonics from built-in actions', () => {
+		createPart(undefined, undefined, [
+			disposables.add(new Action('workbench.action.files.newUntitledFile', '&&New File...')),
+			disposables.add(new Action('test.builtin.unmapped', 'Unmapped')),
+		]);
+
+		const [button, unmappedButton] = fixture.querySelectorAll<HTMLButtonElement>('.ribbon-item');
+		assert.strictEqual(button.getAttribute('aria-label'), 'New File...');
+		assert.strictEqual(button.querySelector('.ribbon-item-label')?.textContent, 'New File...');
+		assert.strictEqual(button.querySelector('.ribbon-item-icon')?.classList.contains('codicon-new-file'), true);
+		assert.strictEqual(unmappedButton.querySelector('.ribbon-item-icon')?.classList.contains('codicon-file'), true);
+	});
+
+	test('closes every built-in collapsed overlay on activity bar mousedown before its click handler runs', () => {
+		let delegate: IContextViewDelegate | undefined;
+		let renderDisposable: IDisposable | undefined;
+		let hidden = false;
+		const overlayElement = mainWindow.document.createElement('div');
+		const activityBarElement = mainWindow.document.createElement('div');
+		fixture.append(overlayElement, activityBarElement);
+		const contextViewService = {
+			showContextView: (newDelegate: IContextViewDelegate) => {
+				delegate = newDelegate;
+				renderDisposable = newDelegate.render(overlayElement);
+				newDelegate.focus?.();
+				return { close: () => renderDisposable?.dispose() };
+			},
+			hideContextView: () => {
+				hidden = true;
+				renderDisposable?.dispose();
+				delegate?.onHide?.();
+			},
+		} as unknown as IContextViewService;
+		createPart(undefined, undefined, [disposables.add(new Action('workbench.action.files.newUntitledFile', 'New File...'))], contextViewService);
+		const fileTab = tab(RibbonBuiltinTabId.File)!;
+		fileTab.dispatchEvent(new mainWindow.MouseEvent('dblclick', { bubbles: true }));
+
+		for (const tabId of [RibbonBuiltinTabId.File, RibbonBuiltinTabId.View, RibbonBuiltinTabId.Help]) {
+			hidden = false;
+			tab(tabId)!.dispatchEvent(new mainWindow.MouseEvent('click', { bubbles: true }));
+
+			const overlayButton = overlayElement.querySelector<HTMLButtonElement>('.ribbon-item')!;
+			assert.strictEqual(mainWindow.document.activeElement, overlayButton);
+			activityBarElement.dispatchEvent(new mainWindow.MouseEvent('mousedown', { bubbles: true }));
+
+			assert.strictEqual(hidden, true, `expected ${tabId} overlay to close`);
+		}
+	});
+
+	test('ignores unrelated context changes and refreshes affected contributions', () => {
+		const contextKeyService = disposables.add(new ContextKeyService(new TestConfigurationService()));
+		const visible = contextKeyService.createKey<boolean>('ribbon.testVisible', true);
+		const unrelated = contextKeyService.createKey<boolean>('ribbon.unrelated', false);
+		ribbonRegistry.setTabs([contribution({ when: 'ribbon.testVisible' })]);
+		createPart(undefined, contextKeyService);
+
+		const originalFileTab = tab(RibbonBuiltinTabId.File)!;
+		unrelated.set(true);
+		assert.strictEqual(tab(RibbonBuiltinTabId.File), originalFileTab);
+
+		visible.set(false);
+		assert.strictEqual(tab('test.ribbon.tab'), undefined);
+	});
+
+	test('updates light and dark icon paths when the color theme changes', () => {
+		const themeService = new TestThemeService(new TestColorTheme({}, ColorScheme.DARK));
+		ribbonRegistry.setTabs([contribution({
+			groups: [{
+				id: 'test',
+				title: 'Test',
+				items: [{
+					command: 'test.ribbon.command',
+					title: 'Test command',
+					icon: { light: 'light.svg', dark: 'dark.svg' },
+				}],
+			}],
+		})]);
+		createPart(themeService);
+
+		assert.match(fileIcon().style.backgroundImage, /dark\.svg/);
+		themeService.setTheme(new TestColorTheme({}, ColorScheme.LIGHT));
+		assert.match(fileIcon().style.backgroundImage, /light\.svg/);
+	});
+
+	test('reserves built-in tab identifiers', () => {
+		assert.strictEqual(isReservedRibbonTabId(RibbonBuiltinTabId.File), true);
+		assert.strictEqual(isReservedRibbonTabId(RibbonBuiltinTabId.View), true);
+		assert.strictEqual(isReservedRibbonTabId(RibbonBuiltinTabId.Help), true);
+		assert.strictEqual(isReservedRibbonTabId('test.ribbon.tab'), false);
+	});
+
+	ensureNoDisposablesAreLeakedInTestSuite();
+});
