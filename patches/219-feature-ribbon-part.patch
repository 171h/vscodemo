+	font-size: 28px;
+	line-height: 1;
+	flex: 0 0 auto;
+}
+
+.ribbon-panel-cell .ribbon-item-label,
+.ribbon-panel-cell-button .ribbon-panel-cell-label {
+	font-size: 11px;
+	line-height: 1.25;
+	color: var(--vscode-ribbon-dropdown-foreground);
