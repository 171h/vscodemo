+	private renderContributionGroup(parent: HTMLElement, tab: IRegisteredRibbonTab, contribution: IRibbonGroupContribution, closeAfterRun: boolean, store: DisposableStore, collapsibleGroups: HTMLElement[]): HTMLButtonElement | undefined {
+		const group = append(parent, $('.ribbon-group'));
+		group.setAttribute('role', 'group');
+		group.setAttribute('aria-label', contribution.title);
+		collapsibleGroups.push(group);
+		const items = append(group, $('.ribbon-items'));
+		this.renderContributionGroupDropdown(group, tab, contribution, store);
+		const responsiveMenus = new Map<string, { definition: IRibbonResponsiveMenuContribution; items: IRibbonItemContribution[] }>();
+		let firstFocusableButton: HTMLButtonElement | undefined;
+		for (const item of contribution.items.filter(item => this.matches(item.when))) {
+			const button = this.renderContributionItem(items, tab, item, closeAfterRun, store);
+			if (item.responsiveMenu) {
+				(items.lastElementChild as HTMLElement).dataset.responsiveMenuSource = item.responsiveMenu.id;
+				const menu = responsiveMenus.get(item.responsiveMenu.id) ?? { definition: item.responsiveMenu, items: [] };
+				menu.items.push(item);
+				responsiveMenus.set(item.responsiveMenu.id, menu);
+			}
+			if (!button.disabled) {
+				firstFocusableButton ??= button;
+			}
+		}
+		for (const [id, menu] of responsiveMenus) {
+			this.renderContributionItem(items, tab, {
+				type: 'dropdown',
+				title: menu.definition.title,
+				icon: menu.definition.icon,
+				menu: { items: menu.items },
+			}, closeAfterRun, store);
+			const element = items.lastElementChild as HTMLElement;
+			element.classList.add('ribbon-responsive-menu');
+			element.dataset.responsiveMenuId = id;
+			element.hidden = true;
+		}
+		append(group, $('div.ribbon-group-title')).textContent = contribution.title;
+		return firstFocusableButton;
+	}
