+/*---------------------------------------------------------------------------------------------
+ *  Copyright (c) Microsoft Corporation. All rights reserved.
+ *  Licensed under the MIT License. See License.txt in the project root for license information.
+ *--------------------------------------------------------------------------------------------*/
+
+import { createDecorator } from '../../../../platform/instantiation/common/instantiation.js';
+import { IRibbonCustomContentContribution } from './ribbonExtensionPoint.js';
+
+export const IRibbonService = createDecorator<IRibbonService>('ribbonService');
+
+/*
+ * 面板下拉的通用描述符。扩展无需自建 HTML 即可获得 Word 风格的紧凑面板外
+ * 壳（边框、阴影、标题、网格化大图标按钮、可分组），由 RibbonPart 统一渲染。
+ *
+ * 两种填充方式：
+ * 1. `sections`：结构化命令网格。每个 section 可有自己的小标题，section 内
+ *    的 items 按 `columns` 排成网格，每格一个"大图标 + label"按钮。
+ *    - 若提供了 `renderItem` 回调，RibbonPart 用它渲染每个 item（典型用法
+ *      是从声明式 `contributes.ribbon` 转发，复用 renderContributionItem）。
+ *    - 否则 RibbonPart 用默认渲染：把每个 item 当作 `{ title, icon }` 显示。
+ * 2. `custom`：隔离 sandbox iframe 中的静态 HTML/CSS（与 menu.custom 一致）。
+ *
+ * `sections` 与 `custom` 可同时存在（custom 排在 sections 之后）。
+ */
+export interface IRibbonPanelItem {
+	readonly title: string;
+	readonly icon?: string | { readonly light: string; readonly dark: string };
+	readonly command?: string;
+	readonly arguments?: readonly unknown[];
+	readonly when?: string;
+	[key: string]: unknown;
+}
+
+export interface IRibbonPanelSection {
+	readonly title?: string;
+	readonly items: readonly IRibbonPanelItem[];
+}
+
+export interface IRibbonPanelDescriptor {
+	readonly title?: string;
+	readonly columns?: number;
+	readonly sections?: readonly IRibbonPanelSection[];
+	readonly custom?: IRibbonCustomContentContribution;
+	readonly renderItem?: (parent: HTMLElement, item: IRibbonPanelItem) => HTMLElement;
+}
+
+export interface IRibbonPanelHandle {
+	/*
+	 * 主动关闭面板。扩展可在执行完命令或用户操作后调用；不调用时由 RibbonPart
+	 * 在点击外部、切 tab、切换菜单时自动关闭。
+	 */
+	close(): void;
+}
+
+export interface IRibbonService {
+	readonly _serviceBrand: undefined;
+	focus(): void;
+	/*
+	 * 在指定 anchor 旁弹出一个 Word 风格的面板下拉。返回一个 handle 用于主动
+	 * 关闭。同一时刻只会有一个面板/菜单打开；若之前已有打开，调用此方法会先
+	 * 关闭旧的再打开新的（不会触发 toggle——若点击的就是当前 anchor，请由调
+	 * 用方自行判断后调用 handle.close()）。
+	 */
+	showPanelDropdown(anchor: HTMLElement, descriptor: IRibbonPanelDescriptor): IRibbonPanelHandle;
+}
