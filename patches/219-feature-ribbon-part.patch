new file mode 100644
index 0000000000000000000000000000000000000000..0fc45fc6eeca9fb12f5281df2d1a63f00aa5403c
--- /dev/null
+++ b/src/vs/workbench/browser/parts/ribbon/ribbonExtensionPoint.ts
@@ -0,0 +1,218 @@
+/*---------------------------------------------------------------------------------------------
+ *  Copyright (c) Microsoft Corporation. All rights reserved.
+ *  Licensed under the MIT License. See License.txt in the project root for license information.
+ *--------------------------------------------------------------------------------------------*/
+
+import { Emitter, Event } from '../../../../base/common/event.js';
+import { IJSONSchema } from '../../../../base/common/jsonSchema.js';
+import { URI } from '../../../../base/common/uri.js';
+import { localize } from '../../../../nls.js';
+import { commandsExtensionPoint } from '../../../services/actions/common/menusExtensionPoint.js';
+import { ExtensionsRegistry } from '../../../services/extensions/common/extensionsRegistry.js';
+
+export interface IRibbonIconPath {
+	readonly light: string;
+	readonly dark: string;
+}
+
+export interface IRibbonItemContribution {
+	readonly command: string;
+	readonly title: string;
+	readonly icon: string | IRibbonIconPath;
+	readonly order?: number;
+	readonly when?: string;
+	readonly arguments?: readonly unknown[];
+}
+
+export interface IRibbonGroupContribution {
+	readonly id: string;
+	readonly title: string;
+	readonly order?: number;
+	readonly when?: string;
+	readonly items: readonly IRibbonItemContribution[];
+}
+
+export interface IRibbonTabContribution {
+	readonly id: string;
+	readonly title: string;
+	readonly order?: number;
+	readonly default?: boolean;
+	readonly when?: string;
+	readonly groups: readonly IRibbonGroupContribution[];
+}
+
+interface IRibbonContribution {
+	readonly tabs: readonly IRibbonTabContribution[];
+}
+
+export interface IRegisteredRibbonTab extends IRibbonTabContribution {
+	readonly extensionId: string;
+	readonly extensionLocation: URI;
+}
+
+export const enum RibbonBuiltinTabId {
+	File = 'workbench.ribbon.file',
+	View = 'workbench.ribbon.view',
+	Help = 'workbench.ribbon.help',
+}
+
+const reservedTabIds = new Set<string>([
+	RibbonBuiltinTabId.File,
+	RibbonBuiltinTabId.View,
+	RibbonBuiltinTabId.Help,
+]);
+
+export function isReservedRibbonTabId(id: string): boolean {
+	return reservedTabIds.has(id);
+}
+
+class RibbonRegistry {
+	private readonly _onDidChange = new Emitter<void>();
+	readonly onDidChange: Event<void> = this._onDidChange.event;
+
+	private _tabs: readonly IRegisteredRibbonTab[] = [];
+
+	get tabs(): readonly IRegisteredRibbonTab[] {
+		return this._tabs;
+	}
+
+	setTabs(tabs: readonly IRegisteredRibbonTab[]): void {
+		this._tabs = tabs;
+		this._onDidChange.fire();
+	}
+}
+
+export const ribbonRegistry = new RibbonRegistry();
+
+const orderProperty: IJSONSchema = {
+	type: 'number',
+	description: localize('ribbon.order', "Controls the order of the contributed Ribbon element."),
+};
+
+const whenProperty: IJSONSchema = {
+	type: 'string',
+	description: localize('ribbon.when', "Condition which must be true to show this Ribbon element."),
+};
+
+const ribbonItemSchema: IJSONSchema = {
+	type: 'object',
+	additionalProperties: false,
+	required: ['command', 'title', 'icon'],
+	properties: {
+		command: { type: 'string', description: localize('ribbon.command', "Identifier of a command declared in the commands contribution point.") },
+		title: { type: 'string', description: localize('ribbon.itemTitle', "Human readable label of the Ribbon command.") },
+		icon: {
+		description: localize('ribbon.icon', "Theme icon such as `{0}`, an extension-relative icon path, or light and dark icon paths.", '$(add)'),
+			anyOf: [
+				{ type: 'string' },
+				{ type: 'object', required: ['light', 'dark'], additionalProperties: false, properties: { light: { type: 'string' }, dark: { type: 'string' } } },
+			],
+		},
+		order: orderProperty,
+		when: whenProperty,
+		arguments: { type: 'array', description: localize('ribbon.arguments', "Arguments passed to the command."), items: {} },
+	},
+};
+
+const ribbonGroupSchema: IJSONSchema = {
+	type: 'object',
+	additionalProperties: false,
+	required: ['id', 'title', 'items'],
+	properties: {
+		id: { type: 'string' },
+		title: { type: 'string' },
+		order: orderProperty,
+		when: whenProperty,
+		items: { type: 'array', minItems: 1, items: ribbonItemSchema },
+	},
+};
+
+const ribbonContributionSchema: IJSONSchema = {
+	description: localize('vscode.extension.contributes.ribbon', "Contributes tabs, groups, and commands to the Workbench Ribbon."),
+	type: 'object',
+	additionalProperties: false,
+	required: ['tabs'],
+	properties: {
+		tabs: {
+			type: 'array',
+			minItems: 1,
+			items: {
+				type: 'object',
+				additionalProperties: false,
+				required: ['id', 'title', 'groups'],
+				properties: {
+					id: { type: 'string' },
+					title: { type: 'string' },
+					order: orderProperty,
+					default: { type: 'boolean' },
+					when: whenProperty,
+					groups: { type: 'array', minItems: 1, items: ribbonGroupSchema },
+				},
+			},
+		},
+	},
+};
+
+const ribbonExtensionPoint = ExtensionsRegistry.registerExtensionPoint<IRibbonContribution>({
+	extensionPoint: 'ribbon',
+	deps: [commandsExtensionPoint],
+	jsonSchema: ribbonContributionSchema,
+});
+
+function orderOf(value: { readonly order?: number }): number {
+	return typeof value.order === 'number' ? value.order : 0;
+}
+
+ribbonExtensionPoint.setHandler((extensions) => {
+	const tabs: IRegisteredRibbonTab[] = [];
+	const tabIds = new Set<string>();
+
+	for (const extension of extensions) {
+		const contribution = extension.value as IRibbonContribution;
+		if (!contribution || !Array.isArray(contribution.tabs)) {
+			extension.collector.error(localize('ribbon.invalidRoot', "The Ribbon contribution must contain a tabs array."));
+			continue;
+		}
+
+		for (const tab of contribution.tabs as readonly IRibbonTabContribution[]) {
+			if (!tab?.id || !tab.title || !Array.isArray(tab.groups)) {
+				extension.collector.error(localize('ribbon.invalidTab', "Each Ribbon tab must define id, title, and groups."));
+				continue;
+			}
+			if (tabIds.has(tab.id)) {
+				extension.collector.error(localize('ribbon.duplicateTab', "Ribbon tab id '{0}' is already registered.", tab.id));
+				continue;
+			}
+			if (isReservedRibbonTabId(tab.id)) {
+				extension.collector.error(localize('ribbon.reservedTab', "Ribbon tab id '{0}' is reserved by the Workbench.", tab.id));
+				continue;
+			}
+
+			const groupIds = new Set<string>();
+			const groups = tab.groups.filter((group: IRibbonGroupContribution) => {
+				if (!group?.id || !group.title || !Array.isArray(group.items)) {
+					extension.collector.error(localize('ribbon.invalidGroup', "Each Ribbon group must define id, title, and items."));
+					return false;
+				}
+				if (groupIds.has(group.id)) {
+					extension.collector.error(localize('ribbon.duplicateGroup', "Ribbon group id '{0}' is duplicated in tab '{1}'.", group.id, tab.id));
+					return false;
+				}
+				groupIds.add(group.id);
+				return true;
+			}).map((group: IRibbonGroupContribution) => ({ ...group, items: [...group.items].sort((a: IRibbonItemContribution, b: IRibbonItemContribution) => orderOf(a) - orderOf(b) || a.command.localeCompare(b.command)) }))
