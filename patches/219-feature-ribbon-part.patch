+	border-bottom: 1px solid var(--vscode-ribbon-dropdown-separator);
+	border-radius: 4px 4px 0 0;
+}
+
+.ribbon-panel-title {
+	font-size: 12px;
+	font-weight: 600;
+	text-transform: uppercase;
+	letter-spacing: 0.04em;
+	opacity: 0.9;
