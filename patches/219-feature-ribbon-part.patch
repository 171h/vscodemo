+	private renderActionGroup(parent: HTMLElement, tab: IBuiltinRibbonTab, groupId: string, actions: readonly IAction[], closeAfterRun: boolean, store: DisposableStore, collapsibleGroups: HTMLElement[]): HTMLButtonElement | undefined {
+		const title = builtinGroupTitle(tab, groupId, actions);
+		const group = append(parent, $('.ribbon-group'));
+		group.setAttribute('role', 'group');
+		group.setAttribute('aria-label', title);
+		group.dataset.groupId = groupId;
+		collapsibleGroups.push(group);
+		const items = append(group, $('.ribbon-items.compact'));
+		this.renderGroupDropdown(group, tab, title, actions, store);
+		let firstFocusableButton: HTMLButtonElement | undefined;
+		for (const action of actions) {
+			const label = mnemonicButtonLabel(action.label, true);
+			const size: RibbonItemSize = actions.length === 1 ? 'full' : actions.length === 2 ? 'half' : 'third';
+			const compactLayouts: IRibbonResponsiveLayoutContribution[] = size === 'full'
+				? [{ size: 'half' }, { size: 'third' }]
+				: size === 'half' ? [{ size: 'third' }] : [];
+			if (this.supportsIconOnlyLayout(action.id)) {
+				compactLayouts.push({ size: 'third', style: 'icon' });
+			}
+			const { button, icon } = this.createButton(items, label, action.enabled, size, 'iconAndLabel', compactLayouts);
+			this.renderBuiltinActionIcon(icon, tab, action);
+			if (!button.disabled) {
+				firstFocusableButton ??= button;
+			}
+			store.add(addDisposableListener(button, EventType.CLICK, () => {
+				if (action instanceof SubmenuAction) {
+					this.contextMenuService.showContextMenu({ getAnchor: () => button, getActions: () => [...action.actions] });
+					return;
+				}
+				void Promise.resolve(action.run()).catch(error => this.notificationService.error(error));
+				if (closeAfterRun) {
+					this.contextViewService.hideContextView();
+				}
+			}));
+		}
+		append(group, $('div.ribbon-group-title')).textContent = title;
+		return firstFocusableButton;
+	}
+
+	private supportsIconOnlyLayout(commandId: string): boolean {
+		return /(?:^|\.)(?:save|saveAll|print|undo|redo|find|search)$/i.test(commandId)
+			|| /(?:save|print|undo|redo|find|search)/i.test(commandId);
+	}
+
+	private renderBuiltinActionIcon(container: HTMLElement, tab: IBuiltinRibbonTab, action: IAction): void {
+		if (action instanceof MenuItemAction || action instanceof SubmenuItemAction) {
+			const actionIcon = action.item.icon;
+			if (ThemeIcon.isThemeIcon(actionIcon)) {
+				container.classList.add(...ThemeIcon.asClassNameArray(actionIcon));
+				return;
+			}
+
+			let iconUri: URI | undefined;
+			if (URI.isUri(actionIcon)) {
+				iconUri = actionIcon;
+			} else if (actionIcon) {
+				iconUri = isDark(this.themeService.getColorTheme().type) ? actionIcon.dark : actionIcon.light;
+			}
+			if (iconUri) {
+				container.style.backgroundImage = asCSSUrl(iconUri);
+				container.classList.add('ribbon-file-icon');
+				return;
+			}
+		}
+
+		container.classList.add(...ThemeIcon.asClassNameArray(builtinActionFallbackIcon(tab, action)));
+	}
