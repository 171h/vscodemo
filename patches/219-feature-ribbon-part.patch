+	--ribbon-icon-size: 40px;
+	flex: 0 0 auto;
+	width: 40px;
+	height: 40px;
+}
+
+.ribbon-dropdown-primary:disabled {
+	opacity: .45;
+	cursor: default;
+}
+
+.ribbon-dropdown-trigger,
+.ribbon-dropdown-footer {
+	display: flex;
+	align-items: center;
+	justify-content: center;
+	gap: 3px;
+	min-height: 22px;
+}
+
+/*
+ * Chevron alignment depends on how many lines the label wraps to at the current
+ * group width. Single-line labels stack the chevron below the label (column) so
+ * every chevron sits on the same horizontal baseline near the button bottom;
+ * double-line labels keep the chevron on the right (row) to avoid pushing it
+ * past the ribbon panel when the second line eats the remaining vertical space.
+ * The line-count class is added at render time by watchRibbonLabelLines().
+ */
+.ribbon-dropdown-trigger.ribbon-label-single,
+.ribbon-dropdown-footer.ribbon-label-single {
+	flex-direction: column;
+	gap: 1px;
+}
+
+.ribbon-dropdown-trigger.ribbon-label-double,
+.ribbon-dropdown-footer.ribbon-label-double {
+	flex-direction: row;
+	align-items: flex-end;
+}
+
+.ribbon-dropdown-trigger {
+	border-top: 1px solid var(--vscode-panel-border);
+}
+
+.ribbon-dropdown-footer .codicon,
+.ribbon-dropdown-trigger .codicon {
+	font-size: 12px;
+}
+
+.ribbon-item-menu {
+	max-width: min(1200px, calc(100vw - 24px));
+	max-height: min(800px, calc(100vh - 24px));
+	overflow: auto;
+	background: var(--vscode-menu-background);
+	color: var(--vscode-menu-foreground);
+	border: 1px solid var(--vscode-menu-border, var(--vscode-panel-border));
+	box-shadow: 0 4px 10px var(--vscode-widget-shadow);
+}
+
